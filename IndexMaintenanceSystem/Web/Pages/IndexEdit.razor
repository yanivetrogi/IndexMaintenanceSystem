@page "/indexes/edit/{IndexId:int}"
@inject DashboardService DashboardService
@inject NavigationManager NavigationManager
@using IndexMaintenanceSystem.Models.Ims

<h3>Edit Index</h3>

@if (index == null)
{
    <div class="p-4">Loading...</div>
}
else
{
    <div class="card mt-3">
        <div class="card-body">
            <EditForm Model="@index" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Database ID</label>
                            <InputNumber class="form-control" @bind-Value="index.DatabaseId" disabled />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Schema</label>
                            <InputText class="form-control" @bind-Value="index.Schema" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Table</label>
                            <InputText class="form-control" @bind-Value="index.Table" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Index Name</label>
                            <InputText class="form-control" @bind-Value="index.Name" placeholder="Leave empty for all indexes on table" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <div class="form-check">
                                <InputCheckbox class="form-check-input" @bind-Value="index.Active" id="activeCheck" />
                                <label class="form-check-label" for="activeCheck">Active</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Schedule ID</label>
                            <InputNumber class="form-control" @bind-Value="index.ScheduleId" placeholder="Leave empty to inherit" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Run Immediately</label>
                            <InputSelect class="form-select" @bind-Value="index.RunImmediately">
                                <option value="">Inherit</option>
                                <option value="true">Yes</option>
                                <option value="false">No</option>
                            </InputSelect>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Rebuild Threshold (%)</label>
                            <input type="number" class="form-control" @bind="index.RebuildThreshold" placeholder="Inherit" min="0" max="100" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Reorganize Threshold (%)</label>
                            <input type="number" class="form-control" @bind="index.ReorganizeThreshold" placeholder="Inherit" min="0" max="100" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Index Min Size (KB)</label>
                            <InputNumber class="form-control" @bind-Value="index.IndexMinSizeKb" placeholder="Inherit" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Online</label>
                            <InputSelect class="form-select" @bind-Value="index.Online">
                                <option value="">Inherit</option>
                                <option value="true">Yes</option>
                                <option value="false">No</option>
                            </InputSelect>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">MAXDOP</label>
                            <input type="number" class="form-control" @bind="index.Maxdop" placeholder="Inherit" min="0" max="255" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Sort In TempDB</label>
                            <InputSelect class="form-select" @bind-Value="index.SortInTempdb">
                                <option value="">Inherit</option>
                                <option value="true">Yes</option>
                                <option value="false">No</option>
                            </InputSelect>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Exclude Last Partition</label>
                            <InputSelect class="form-select" @bind-Value="index.ExcludeLastPartition">
                                <option value="">Inherit</option>
                                <option value="true">Yes</option>
                                <option value="false">No</option>
                            </InputSelect>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a href="/indexes" class="btn btn-secondary ms-2">Cancel</a>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public int IndexId { get; set; }

    private IndexMaintenanceSystem.Models.Ims.Index? index;

    protected override async Task OnInitializedAsync()
    {
        index = await DashboardService.GetIndexAsync(IndexId);
    }

    private async Task HandleValidSubmit()
    {
        if (index != null)
        {
            await DashboardService.UpdateIndexAsync(index);
            NavigationManager.NavigateTo("/indexes");
        }
    }
}

