@page "/schedules/edit/{id:int}"
@page "/schedules/add"
@inject DashboardService DashboardService
@inject NavigationManager Navigation
@using IndexMaintenanceSystem.Models.Ims

<h3>@(Id == 0 ? "Add Schedule" : "Edit Schedule")</h3>

@if (schedule == null)
{
    <p>Loading...</p>
}
else
{
    <EditForm Model="schedule" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row">
            <div class="col-md-4">
                <h4>General</h4>
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <InputText class="form-control" @bind-Value="schedule.Name" />
                </div>


                <h4 class="mt-4">Active Period</h4>
                 <div class="mb-3">
                    <label class="form-label">Start Date (YYYYMMDD)</label>
                    <InputNumber class="form-control" @bind-Value="schedule.ActiveStartDate" />
                </div>
                 <div class="mb-3">
                    <label class="form-label">End Date (YYYYMMDD)</label>
                    <InputNumber class="form-control" @bind-Value="schedule.ActiveEndDate" />
                </div>
                 <div class="mb-3">
                    <label class="form-label">Start Time (e.g., 093000 = 9:30 AM)</label>
                    <InputNumber class="form-control" @bind-Value="schedule.ActiveStartTime" />
                </div>
                
                <h5 class="mt-3" style="visibility: hidden;">Spacer</h5>

                 <div class="mb-3">
                    <label class="form-label">End Time (e.g., 235959 = 11:59:59 PM)</label>
                    <InputNumber class="form-control" @bind-Value="schedule.ActiveEndTime" />
                </div>
            </div>
            
            <div class="col-md-8">
                 <h4 style="visibility: hidden;">General</h4>
                 <div class="mb-3">
                    <label class="form-label">Description</label>
                    <InputText class="form-control" @bind-Value="schedule.Description" />
                </div>

                <h4 class="mt-4">Frequency Settings</h4>
                <div class="mb-3">
                    <label class="form-label">Schedule Type</label>
                    <InputSelect class="form-select" @bind-Value="schedule.FreqType">
                        <option value="1">Once</option>
                        <option value="4">Daily</option>
                        <option value="8">Weekly</option>
                        <option value="16">Monthly</option>
                        <option value="32">Monthly Relative</option>
                        <option value="64">Startup</option>
                        <option value="128">Idle</option>
                    </InputSelect>
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        @if (schedule.FreqType == 4) { <text>Recurs every (Days)</text> }
                        else if (schedule.FreqType == 8) { <text>Days of Week (Bitmask Sum)</text> }
                        else if (schedule.FreqType == 16) { <text>Day of Month</text> }
                        else if (schedule.FreqType == 32) { <text>Day Type (1=Sun, 2=Mon... 8=Day, 9=Weekday, 10=Weekend)</text> }
                        else { <text>Interval</text> }
                    </label>
                    <InputNumber class="form-control" @bind-Value="schedule.FreqInterval" />
                    @if (schedule.FreqType == 8)
                    {
                        <small class="text-muted d-block mt-1">
                            Sum the values for days: Sun=1, Mon=2, Tue=4, Wed=8, Thu=16, Fri=32, Sat=64.
                            <br>Example: Mon+Wed+Fri = 2+8+32 = 42.
                        </small>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        @if (schedule.FreqType == 8) { <text>Recur every (Weeks)</text> }
                        else if (schedule.FreqType == 16 || schedule.FreqType == 32) { <text>Recur every (Months)</text> }
                        else { <text>Recurrence Factor (Unused)</text> }
                    </label>
                     <InputNumber class="form-control" @bind-Value="schedule.FreqRecurrenceFactor" />
                </div>

                <h5 class="mt-3">Daily Frequency</h5>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Unit</label>
                        <InputSelect class="form-select" @bind-Value="schedule.FreqSubdayType">
                            <option value="1">At specified time</option>
                            <option value="2">Seconds</option>
                            <option value="4">Minutes</option>
                            <option value="8">Hours</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Value</label>
                        <InputNumber class="form-control" @bind-Value="schedule.FreqSubdayInterval" />
                         <small class="text-muted">Runs every X (Unit)</small>
                    </div>
                </div>

                @if (schedule.FreqType == 32)
                {
                    <div class="mb-3">
                        <label class="form-label">Monthly Relative Ordinal</label>
                        <InputSelect class="form-select" @bind-Value="schedule.FreqRelativeInterval">
                            <option value="1">First</option>
                            <option value="2">Second</option>
                            <option value="4">Third</option>
                            <option value="8">Fourth</option>
                            <option value="16">Last</option>
                        </InputSelect>
                    </div>
                }
        </div>
    </div>



        <button type="submit" class="btn btn-primary mt-3">Save</button>
        <button type="button" class="btn btn-secondary mt-3 ms-2" @onclick="Cancel">Cancel</button>
    </EditForm>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Schedule? schedule;

    protected override async Task OnInitializedAsync()
    {
        if (Id == 0)
        {
            schedule = new Schedule
            {
                Name = "",
                FreqType = 4, // Daily
                FreqInterval = 1,
                ActiveStartDate = int.Parse(DateTime.Now.ToString("yyyyMMdd")),
                ActiveStartTime = 0,
                ActiveEndDate = 99991231,
                ActiveEndTime = 235959
            };
        }
        else
        {
            schedule = await DashboardService.GetScheduleAsync(Id);
        }
    }

    private async Task HandleValidSubmit()
    {
        if (schedule != null)
        {
            if (Id == 0)
            {
                 await DashboardService.AddScheduleAsync(schedule);
            }
            else
            {
                await DashboardService.UpdateScheduleAsync(schedule);
            }
            Navigation.NavigateTo("/schedules");
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/schedules");
    }
}

