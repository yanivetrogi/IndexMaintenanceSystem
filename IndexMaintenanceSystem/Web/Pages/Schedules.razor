@page "/schedules"
@inject DashboardService DashboardService
@using IndexMaintenanceSystem.Models.Ims

<h3>Schedules</h3>

<div class="mb-3">
    <a href="/schedules/add" class="btn btn-primary">Add Schedule</a>
</div>

<div class="card mt-3">
    <div class="card-body p-0">
        @if (schedules == null)
        {
            <div class="p-4">Loading...</div>
        }
        else
        {
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Start Date</th>
                        <th>Start Time</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var schedule in schedules)
                    {
                        <tr>
                            <td>@schedule.ScheduleId</td>
                            <td>@schedule.Name</td>
                            <td>@schedule.FreqType</td>
                            <td>@schedule.ActiveStartDate</td>
                            <td>@schedule.ActiveStartTime</td>
                            <td>
                                <a href="/schedules/edit/@schedule.ScheduleId" class="btn btn-sm btn-outline-primary">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private IEnumerable<Schedule>? schedules;

    protected override async Task OnInitializedAsync()
    {
        schedules = await DashboardService.GetSchedulesAsync();
    }
}

