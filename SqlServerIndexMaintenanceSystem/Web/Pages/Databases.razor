@page "/databases"
@inject DashboardService DashboardService
@using SqlServerIndexMaintenanceSystem.Models.Ims

<h3>Databases</h3>

<div class="card mt-3">
    <div class="card-body p-0">
        @if (databases == null)
        {
            <div class="p-4">Loading...</div>
        }
        else
        {
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Server Id</th>
                        <th>Name</th>
                        <th>Active</th>
                        <th>Schedule Id</th>
                        <th>Run Immediately</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var db in databases)
                    {
                        <tr>
                            <td>@db.DatabaseId</td>
                            <td>@db.ServerId</td>
                            <td>@db.Name</td>
                             <td>
                                @if(db.Active) { <span class="badge bg-success">Yes</span> } else { <span class="badge bg-secondary">No</span> }
                            </td>
                            <td>@db.ScheduleId</td>
                            <td>@db.RunImmediately</td>
                            <td>
                                <a href="/databases/edit/@db.DatabaseId" class="btn btn-sm btn-outline-primary">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private IEnumerable<Database>? databases;

    protected override async Task OnInitializedAsync()
    {
        databases = await DashboardService.GetDatabasesAsync();
    }
}
