@page "/schedules/edit/{id:int}"
@inject DashboardService DashboardService
@inject NavigationManager Navigation
@using SqlServerIndexMaintenanceSystem.Models.Ims

<h3>Edit Schedule</h3>

@if (schedule == null)
{
    <p>Loading...</p>
}
else
{
    <EditForm Model="schedule" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row">
            <div class="col-md-6">
                <h4>General</h4>
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <InputText class="form-control" @bind-Value="schedule.Name" />
                </div>
                 <div class="mb-3">
                    <label class="form-label">Description (Read Only)</label>
                    <input class="form-control" value="@schedule.Description" readonly />
                </div>
            </div>
            
            <div class="col-md-6">
                <h4>Frequency Settings</h4>
                <div class="mb-3">
                    <label class="form-label">Freq Type</label>
                    <InputNumber class="form-control" @bind-Value="schedule.FreqType" />
                    <small class="text-muted">1=Once, 4=Daily, 8=Weekly, 16=Monthly, 32=Monthly Relative, 64=Startup, 128=Idle</small>
                </div>
                <div class="mb-3">
                    <label class="form-label">Freq Interval</label>
                    <InputNumber class="form-control" @bind-Value="schedule.FreqInterval" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Freq Subday Type</label>
                    <InputNumber class="form-control" @bind-Value="schedule.FreqSubdayType" />
                    <small class="text-muted">1=Time, 2=Seconds, 4=Minutes, 8=Hours</small>
                </div>
                <div class="mb-3">
                    <label class="form-label">Freq Subday Interval</label>
                    <InputNumber class="form-control" @bind-Value="schedule.FreqSubdayInterval" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Freq Relative Interval</label>
                    <InputNumber class="form-control" @bind-Value="schedule.FreqRelativeInterval" />
                    <small class="text-muted">1=First, 2=Second, 4=Third, 8=Fourth, 16=Last</small>
                </div>
                 <div class="mb-3">
                    <label class="form-label">Freq Recurrence Factor</label>
                    <InputNumber class="form-control" @bind-Value="schedule.FreqRecurrenceFactor" />
                </div>
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-md-6">
                <h4>Active Period</h4>
                 <div class="mb-3">
                    <label class="form-label">Start Date (YYYYMMDD)</label>
                    <InputNumber class="form-control" @bind-Value="schedule.ActiveStartDate" />
                </div>
                 <div class="mb-3">
                    <label class="form-label">End Date (YYYYMMDD)</label>
                    <InputNumber class="form-control" @bind-Value="schedule.ActiveEndDate" />
                </div>
                 <div class="mb-3">
                    <label class="form-label">Start Time (HHMMSS)</label>
                    <InputNumber class="form-control" @bind-Value="schedule.ActiveStartTime" />
                </div>
                 <div class="mb-3">
                    <label class="form-label">End Time (HHMMSS)</label>
                    <InputNumber class="form-control" @bind-Value="schedule.ActiveEndTime" />
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary mt-3">Save</button>
        <button type="button" class="btn btn-secondary mt-3 ms-2" @onclick="Cancel">Cancel</button>
    </EditForm>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Schedule? schedule;

    protected override async Task OnInitializedAsync()
    {
        schedule = await DashboardService.GetScheduleAsync(Id);
    }

    private async Task HandleValidSubmit()
    {
        if (schedule != null)
        {
            await DashboardService.UpdateScheduleAsync(schedule);
            Navigation.NavigateTo("/schedules");
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/schedules");
    }
}
